# Copy to .env.local and fill in real values (.env.local is gitignored).

# OpenWeatherMap API key for the WeatherApp mini-app (libs/weather-app).
# Get one at https://openweathermap.org/api. NEXT_PUBLIC_ = exposed to the
# browser bundle, which is required here because the fetch runs client-side.
NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=
